# =============================================================================
# DR Geopolitical Alert — Secrets Profile
# =============================================================================
# 1. Copy this file:  cp secrets.profile.example secrets.profile
# 2. Fill in your values below
# 3. Run:            ./bootstrap_secrets.sh
#
# secrets.profile is in .gitignore — never commit it.
# =============================================================================

# AWS region to write SSM parameters (must match CDK_DEPLOY_REGION)
AWS_REGION=us-west-2

# --- Conflict collector ---
# ACLED API key: https://acleddata.com/acleddatanerd/
ACLED_API_KEY=

# ACLED account email (same account as above)
ACLED_EMAIL=

# UCDP access token: https://ucdp.uu.se/apidocs/
UCDP_ACCESS_TOKEN=

# --- BGP / Network collector ---
# Cloudflare Radar API token: https://developers.cloudflare.com/radar/
CF_RADAR_TOKEN=

# --- Infrastructure collector (optional) ---
# Cloudflare API token (falls back to RIPE Atlas if empty)
CLOUDFLARE_API_TOKEN=

# --- Slack notifications ---
# Incoming Webhook URL: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
